      "tags": ["utility", "video-processing", "metadata"],
      "complexity": "simple"
    },
    {
      "id": "function:app.py:load_datasets",
      "type": "function",
      "name": "load_datasets",
      "filePath": "app.py",
      "lineRange": [150, 288],
      "summary": "Loads pickle stubs for tracking data and aggregates locomotion statistics, speed calculations, and proximity-based shot attribution for all players.",
      "tags": ["data-loader", "telemetry", "metrics-aggregation"],
      "complexity": "complex"
    },
    {
      "id": "function:app.py:load_rally_log",
      "type": "function",
      "name": "load_rally_log",
      "filePath": "app.py",
      "lineRange": [294, 344],
