      "tags": ["data-loader", "segmentation", "analytics"],
      "complexity": "moderate"
    },
    {
      "id": "file:court_line_detector/mini_court.py",
      "type": "file",
      "name": "mini_court.py",
      "filePath": "court_line_detector/mini_court.py",
      "summary": "Defines the MiniCourt class, which uses homography transformation to project 2D camera coordinates onto a top-down, real-world representation of a Pickleball court.",
      "tags": ["computer-vision", "homography", "court-mapping", "visualization"],
      "complexity": "complex"
    },
    {
      "id": "class:court_line_detector/mini_court.py:MiniCourt",
      "type": "class",
      "name": "MiniCourt",
      "filePath": "court_line_detector/mini_court.py",
      "lineRange": [6, 208],
      "summary": "Top-down 2D mapping manager that computes homography matrices, transforms pixel coordinates to court-space feet, and draws players, ball, and officiating calls on a minimap canvas.",
      "tags": ["mapping-manager", "coordinate-transform", "drawing-utility"],
      "complexity": "complex"
    },
    {
      "id": "function:court_line_detector/mini_court.py:MiniCourt:__init__",
      "type": "function",
      "name": "MiniCourt.__init__",
      "filePath": "court_line_detector/mini_court.py",
      "lineRange": [7, 26],
      "summary": "Initializes the top-down canvas dimensions, official pickleball boundaries in feet, and triggers homography matrix loading.",
      "tags": ["constructor", "initialization"],
      "complexity": "simple"
    },
    {
      "id": "function:court_line_detector/mini_court.py:MiniCourt:load_homography_matrix",
      "type": "function",
      "name": "MiniCourt.load_homography_matrix",
      "filePath": "court_line_detector/mini_court.py",
      "lineRange": [27, 64],
      "summary": "Loads pre-defined court keypoints from a pickle file and computes the 3x3 homography matrix mapping image space to physical court dimensions.",
      "tags": ["data-loader", "homography-calculation", "cv2"],
      "complexity": "moderate"
    },
    {
      "id": "function:court_line_detector/mini_court.py:MiniCourt:draw_mini_court_base",
      "type": "function",
      "name": "MiniCourt.draw_mini_court_base",
      "filePath": "court_line_detector/mini_court.py",
      "lineRange": [76, 104],
      "summary": "Renders the static boundaries of the pickleball court, including the kitchen line, center line, and net line, onto a dark background canvas.",
      "tags": ["drawing-utility", "canvas-rendering"],
      "complexity": "moderate"
    },
    {
      "id": "function:court_line_detector/mini_court.py:MiniCourt:transform_point",
      "type": "function",
      "name": "MiniCourt.transform_point",
      "filePath": "court_line_detector/mini_court.py",
      "lineRange": [106, 117],
      "summary": "Applies perspective transformation to project 2D image coordinates to physical ground coordinates in feet.",
      "tags": ["coordinate-transform", "computer-vision"],
      "complexity": "simple"
    },
    {
      "id": "function:court_line_detector/mini_court.py:MiniCourt:draw_points_on_mini_court",
      "type": "function",
      "name": "MiniCourt.draw_points_on_mini_court",
      "filePath": "court_line_detector/mini_court.py",
      "lineRange": [118, 208],
      "summary": "Draws players, the ball (interpolated or detected), and recent bounce line calls (IN/OUT) onto the mini-court minimap canvas.",
      "tags": ["visualization", "rendering", "tracking-overlay"],
      "complexity": "complex"
    },
    {
      "id": "file:utils/officiating_engine.py",
      "type": "file",
      "name": "officiating_engine.py",
      "filePath": "utils/officiating_engine.py",
      "summary": "Provides the OfficiatingEngine class, which detects when a ball bounce is IN or OUT and overlays a broadcast-style banner with the call onto the video frame.",
      "tags": ["officiating", "rule-engine", "video-overlay", "broadcast-graphics"],
      "complexity": "moderate"
    },
    {
      "id": "class:utils/officiating_engine.py:OfficiatingEngine",
      "type": "class",
      "name": "OfficiatingEngine",
      "filePath": "utils/officiating_engine.py",
      "lineRange": [6, 118],
      "summary": "Officiating manager class that computes line calls for bounce events and handles visual overlays of officiating calls.",
      "tags": ["analytics-engine", "rule-validation", "overlay-renderer"],
      "complexity": "moderate"
    },
    {
      "id": "function:utils/officiating_engine.py:OfficiatingEngine:get_line_calls",
      "type": "function",
      "name": "OfficiatingEngine.get_line_calls",
      "filePath": "utils/officiating_engine.py",
      "lineRange": [10, 49],
      "summary": "Iterates over ball events to identify bounce frames, converts the bounce coordinates to physical court dimensions, and determines if the bounce was IN or OUT.",
      "tags": ["bounds-checker", "coordinate-projection", "event-processing"],
      "complexity": "moderate"
    },
    {
      "id": "function:utils/officiating_engine.py:OfficiatingEngine:draw_calls_on_video",
      "type": "function",
      "name": "OfficiatingEngine.draw_calls_on_video",
      "filePath": "utils/officiating_engine.py",
      "lineRange": [51, 118],
      "summary": "Applies a translucent dark banner and large BGR text overlays (\"IN\" in green, \"OUT\" in red) onto video frames for bounce occurrences.",
      "tags": ["broadcast-style", "rendering", "overlay"],
      "complexity": "complex"
    },
    {
      "id": "file:utils/stats_telemetry_tracker.py",
      "type": "file",
      "name": "stats_telemetry_tracker.py",
      "filePath": "utils/stats_telemetry_tracker.py",
      "summary": "Provides the StatsTelemetryTracker class, which records and computes locomotion telemetry (speed, distance) and proximity-based hit attribution for individual players, and draws a HUD overlay.",
      "tags": ["statistics", "locomotion-analytics", "telemetry", "hud-overlay"],
      "complexity": "moderate"
    },
    {
      "id": "class:utils/stats_telemetry_tracker.py:StatsTelemetryTracker",
      "type": "class",
      "name": "StatsTelemetryTracker",
      "filePath": "utils/stats_telemetry_tracker.py",
      "lineRange": [7, 170],
      "summary": "Performance metrics tracker class that aggregates match locomotion data, attributes hits to players, and maintains a historical snapshot of player metrics.",
      "tags": ["analytics-engine", "data-accumulator", "overlay-renderer"],
      "complexity": "complex"
    },
    {
      "id": "function:utils/stats_telemetry_tracker.py:StatsTelemetryTracker:__init__",
      "type": "function",
      "name": "StatsTelemetryTracker.__init__",
      "filePath": "utils/stats_telemetry_tracker.py",
      "lineRange": [8, 19],
      "summary": "Initializes telemetry tracker settings, instantiates a MiniCourt module, and seeds empty stat structures for players 1 to 4.",
      "tags": ["constructor", "initialization"],
      "complexity": "simple"
    },
    {
      "id": "function:utils/stats_telemetry_tracker.py:StatsTelemetryTracker:process_match_telemetry",
      "type": "function",
      "name": "StatsTelemetryTracker.process_match_telemetry",
      "filePath": "utils/stats_telemetry_tracker.py",
      "lineRange": [21, 113],
      "summary": "Processes tracking coordinates frame-by-frame to compute distances and instantaneous speed, and detects player hits using ball-proximity measurements.",
      "tags": ["data-processor", "speed-calculator", "shot-attribution"],
      "complexity": "complex"
    },
    {
      "id": "function:utils/stats_telemetry_tracker.py:StatsTelemetryTracker:draw_stats_hud",
      "type": "function",
      "name": "StatsTelemetryTracker.draw_stats_hud",
      "filePath": "utils/stats_telemetry_tracker.py",
