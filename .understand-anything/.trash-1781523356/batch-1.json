      "filePath": "court_line_detector/manual_court_selector.py",
      "lineRange": [5, 74],
      "summary": "Detector class that allows manual annotation of 12 court keypoints on a video frame and saves them for later tracking overlay.",
      "tags": ["manual-annotation", "court-detector", "cv2-mouse-callback"],
      "complexity": "moderate"
    },
    {
      "id": "function:court_line_detector/manual_court_selector.py:ManualCourtDetector.get_keypoints",
      "type": "function",
      "name": "ManualCourtDetector.get_keypoints",
      "filePath": "court_line_detector/manual_court_selector.py",
      "lineRange": [9, 60],
      "summary": "Initializes an OpenCV window to collect 12 keypoint locations from user mouse clicks, with stub file loading/saving support.",
      "tags": ["keypoints-collection", "opencv-mouse-events", "stub-caching"],
      "complexity": "moderate"
    },
    {
      "id": "function:court_line_detector/manual_court_selector.py:ManualCourtDetector.draw_keypoints_on_video",
      "type": "function",
