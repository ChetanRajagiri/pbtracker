    },
    {
      "id": "file:main.py",
      "type": "file",
      "name": "main.py",
      "filePath": "main.py",
      "summary": "The main orchestrator and execution entry point of the pickleball tracking and telemetry video processing pipeline.",
      "tags": ["entry-point", "orchestrator", "video-processing", "pipeline"],
      "complexity": "complex"
    },
    {
      "id": "function:main.py:main",
      "type": "function",
      "name": "main",
      "filePath": "main.py",
      "lineRange": [15, 232],
      "summary": "Initializes detectors/trackers, runs the player and ball detection loops (utilizing stub caches), computes telemetry and officiating calls, and renders the annotated video HUD output.",
      "tags": ["orchestration-loop", "video-stream", "hud-overlay", "rendering"],
      "complexity": "complex"
    },
    {
      "id": "file:trackers/ball_tracker.py",
      "type": "file",
      "name": "ball_tracker.py",
      "filePath": "trackers/ball_tracker.py",
      "summary": "Implements the ball tracking system using a YOLO v8/v5 model and Pandas-based interpolation to estimate missing frames.",
      "tags": ["ball-tracking", "yolo-object-detection", "pandas-interpolation", "computer-vision"],
      "complexity": "moderate"
    },
    {
      "id": "class:trackers/ball_tracker.py:BallTracker",
      "type": "class",
      "name": "BallTracker",
      "filePath": "trackers/ball_tracker.py",
      "lineRange": [7, 144],
      "summary": "A tracker class responsible for detecting the pickleball across frames and smoothing trajectories using interpolation.",
      "tags": ["tracker-class", "ball-detection", "bbox-drawing"],
      "complexity": "moderate"
    },
    {
      "id": "function:trackers/ball_tracker.py:BallTracker.interpolate_ball_positions",
      "type": "function",
      "name": "BallTracker.interpolate_ball_positions",
      "filePath": "trackers/ball_tracker.py",
      "lineRange": [12, 49],
      "summary": "Interpolates missing ball positions in a sequence using linear interpolation and backward fill to handle detection flickering.",
      "tags": ["interpolation", "trajectory-smoothing", "pandas-df"],
      "complexity": "moderate"
    },
    {
      "id": "function:trackers/ball_tracker.py:BallTracker.detect_frames",
      "type": "function",
      "name": "BallTracker.detect_frames",
      "filePath": "trackers/ball_tracker.py",
      "lineRange": [51, 95],
      "summary": "Performs YOLO inference on a sequence of frames to locate the ball, with optional caching via pickle stub files.",
      "tags": ["yolo-inference", "object-detection", "stub-caching"],
      "complexity": "moderate"
    },
    {
      "id": "function:trackers/ball_tracker.py:BallTracker.draw_bboxes",
      "type": "function",
      "name": "BallTracker.draw_bboxes",
      "filePath": "trackers/ball_tracker.py",
      "lineRange": [97, 144],
      "summary": "Annotates the ball bounding boxes and center dots onto frames, using green for detected and pink for interpolated coordinates.",
      "tags": ["visualization", "opencv-drawing", "bbox-overlay"],
      "complexity": "moderate"
    },
    {
      "id": "file:utils/auto_player_filter.py",
      "type": "file",
      "name": "auto_player_filter.py",
      "filePath": "utils/auto_player_filter.py",
      "summary": "Performs automatic player isolation, spectator purging, and Re-ID mapping using L2-normalized templates and quadrant sorting.",
      "tags": ["player-filtration", "re-identification", "quadrant-sorting", "court-bounds-filter"],
      "complexity": "complex"
    },
    {
      "id": "function:utils/auto_player_filter.py:expand_polygon_asymmetric",
      "type": "function",
      "name": "expand_polygon_asymmetric",
      "filePath": "utils/auto_player_filter.py",
      "lineRange": [6, 28],
      "summary": "Asymmetrically expands a court bounding polygon to include out-of-bounds player positions relative to baseline heights.",
      "tags": ["polygon-expansion", "coordinate-transform", "court-boundary"],
      "complexity": "moderate"
    },
    {
      "id": "class:utils/auto_player_filter.py:AutoPlayerFilter",
      "type": "class",
      "name": "AutoPlayerFilter",
      "filePath": "utils/auto_player_filter.py",
      "lineRange": [30, 334],
      "summary": "Filters raw player track detections, purges off-court spectators, and maps remaining tracks to Master IDs 1-4 using appearance embeddings.",
      "tags": ["filtration-engine", "appearance-embeddings", "reid", "hungarian-matching"],
      "complexity": "complex"
    },
    {
      "id": "function:utils/auto_player_filter.py:AutoPlayerFilter.run_filtration",
      "type": "function",
      "name": "AutoPlayerFilter.run_filtration",
      "filePath": "utils/auto_player_filter.py",
      "lineRange": [47, 333],
      "summary": "Executes a seeding pass to lock player template embeddings and a matching pass to filter and align all frames to Master IDs.",
      "tags": ["reid-pipeline", "consecutive-frames-seeding", "cosine-similarity"],
      "complexity": "complex"
    },
    {
      "id": "file:utils/ball_physics_analyzer.py",
      "type": "file",
      "name": "ball_physics_analyzer.py",
      "filePath": "utils/ball_physics_analyzer.py",
      "summary": "Analyzes ball trajectory, velocity, and acceleration to detect physics events (bounces and paddle hits) with temporal cooldown constraints.",
      "tags": ["physics-analysis", "trajectory-events", "velocity-calculation", "cooldown-lockout"],
      "complexity": "moderate"
    },
    {
      "id": "class:utils/ball_physics_analyzer.py:BallPhysicsAnalyzer",
      "type": "class",
      "name": "BallPhysicsAnalyzer",
      "filePath": "utils/ball_physics_analyzer.py",
      "lineRange": [6, 193],
      "summary": "Analyzer class that processes ball coordinate stubs to calculate kinematics and identify court bounces and paddle hits.",
      "tags": ["kinematics-engine", "event-detector", "ball-physics"],
      "complexity": "moderate"
    },
    {
      "id": "function:utils/ball_physics_analyzer.py:BallPhysicsAnalyzer.load_and_preprocess",
      "type": "function",
      "name": "BallPhysicsAnalyzer.load_and_preprocess",
      "filePath": "utils/ball_physics_analyzer.py",
      "lineRange": [14, 58],
      "summary": "Loads ball tracking stubs, interpolates missing coordinates, and applies a rolling mean window filter to smooth pixel jitter.",
      "tags": ["data-preprocessing", "pandas-interpolation", "rolling-filter"],
      "complexity": "moderate"
    },
    {
      "id": "function:utils/ball_physics_analyzer.py:BallPhysicsAnalyzer.compute_kinematics",
      "type": "function",
      "name": "BallPhysicsAnalyzer.compute_kinematics",
      "filePath": "utils/ball_physics_analyzer.py",
      "lineRange": [60, 74],
      "summary": "Computes velocity components, acceleration components, and their magnitudes from smoothed coordinates.",
      "tags": ["kinematics", "velocity", "acceleration"],
      "complexity": "simple"
    },
    {
      "id": "function:utils/ball_physics_analyzer.py:BallPhysicsAnalyzer.detect_events",
      "type": "function",
      "name": "BallPhysicsAnalyzer.detect_events",
      "filePath": "utils/ball_physics_analyzer.py",
      "lineRange": [76, 173],
      "summary": "Detects court floor bounces and paddle hits based on acceleration magnitude inflections and velocity sign changes with temporal lockout.",
      "tags": ["event-detection", "bounce-detection", "hit-detection"],
      "complexity": "complex"
    }
